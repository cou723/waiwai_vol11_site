---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "PAG3B — 天下一キーボードわいわい会 vol.11",
  description = "あなたの手の形を測定して、あなただけの立体キーボードを自動生成する。PAG3B展示サイト。",
}: Props = Astro.props;

const canonicalURL = Astro.url.href;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="ja_JP" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <link rel="canonical" href={canonicalURL} />

    <style is:global>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+JP:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap");

      :root {
        --color-bg-primary: #08080c;
        --color-bg-secondary: #111115;
        --color-bg-tertiary: #1a1a1e;
        --color-accent: #3b82f6;
        --color-accent-light: #60a5fa;
        --color-accent-dark: #2563eb;
        --color-text-primary: #f5f5f0;
        --color-text-secondary: #9ca3af;
        --color-border: #e5e5e5;
        --color-border-subtle: rgba(229, 229, 229, 0.15);
        --color-nav-bg: rgba(8, 8, 12, 0.9);
        --color-badge-bg: rgba(8, 8, 12, 0.8);

        --spacing-xs: 0.25rem;
        --spacing-sm: 0.5rem;
        --spacing-md: 1rem;
        --spacing-lg: 2rem;
        --spacing-xl: 4rem;
        --spacing-2xl: 6rem;

        --font-japanese: "Noto Sans JP", sans-serif;
        --font-headline: "Space Grotesk", sans-serif;
        --font-body: "Inter", sans-serif;
        --font-mono: "JetBrains Mono", monospace;

        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 12px;
        --radius-xl: 16px;

        --transition-fast: 150ms ease;
        --transition-base: 250ms ease;
        --transition-slow: 500ms cubic-bezier(0.4, 0, 0.2, 1);
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        font-size: 16px;
        scroll-padding-top: 70px;
      }

      body {
        font-family: var(--font-japanese), var(--font-body);
        background-color: var(--color-bg-primary);
        color: var(--color-text-primary);
        line-height: 1.6;
        overflow-x: hidden;
        text-autospace: normal;
        overflow-wrap: anywhere;
        word-break: normal;
        line-break: strict;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-family: var(--font-headline);
        font-weight: 600;
        line-height: 1.2;
        margin-bottom: var(--spacing-md);
        color: var(--color-text-primary);
      }

      h1 {
        font-size: clamp(2rem, 5vw, 4rem);
      }
      h2 {
        font-size: clamp(1.5rem, 3vw, 2.5rem);
      }
      h3 {
        font-size: clamp(1.125rem, 2vw, 1.75rem);
      }

      p {
        margin-bottom: var(--spacing-md);
        color: var(--color-text-secondary);
      }

      a {
        color: var(--color-accent);
        text-decoration: none;
        transition: color var(--transition-fast);
      }

      a:hover {
        color: var(--color-accent-light);
      }

      code,
      .code {
        font-family: var(--font-mono);
        background: var(--color-bg-tertiary);
        padding: 0.2em 0.4em;
        border-radius: var(--radius-sm);
        font-size: 0.9em;
      }

      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--color-bg-primary);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--color-bg-tertiary);
        border-radius: var(--radius-sm);
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--color-accent);
      }

      ::selection {
        background: var(--color-accent);
        color: white;
      }
      :focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
      }

      .grid-background {
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(59, 130, 246, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(59, 130, 246, 0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
        z-index: -1;
      }

      .noise-overlay {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9998;
        opacity: 0.02;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      }

      .accent-text {
        color: var(--color-accent);
      }

      .card-border {
        border: 1px solid var(--color-border-subtle);
        transition: border-color var(--transition-base);
      }
      .card-border:hover {
        border-color: var(--color-accent);
      }

      .container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 var(--spacing-lg);
      }

      .container-narrow {
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
        padding: 0 var(--spacing-lg);
      }

      .section {
        position: relative;
        padding: var(--spacing-2xl) 0;
      }

      .section--secondary {
        background-color: var(--color-bg-secondary);
      }

      @media (prefers-color-scheme: light) {
        :root {
          --color-bg-primary: #f8f8fc;
          --color-bg-secondary: #f0f0f5;
          --color-bg-tertiary: #e4e4ea;
          --color-accent: #2563eb;
          --color-accent-light: #3b82f6;
          --color-accent-dark: #1d4ed8;
          --color-text-primary: #1a1a1e;
          --color-text-secondary: #6b7280;
          --color-border: #1a1a1e;
          --color-border-subtle: rgba(0, 0, 0, 0.12);
          --color-nav-bg: rgba(248, 248, 252, 0.92);
          --color-badge-bg: rgba(240, 240, 245, 0.9);
        }

        .grid-background {
          background-image:
            linear-gradient(rgba(37, 99, 235, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(37, 99, 235, 0.05) 1px, transparent 1px);
        }

        ::-webkit-scrollbar-track {
          background: var(--color-bg-primary);
        }
        ::-webkit-scrollbar-thumb {
          background: var(--color-bg-tertiary);
        }
      }

      @media (max-width: 768px) {
        :root {
          --spacing-lg: 1.5rem;
          --spacing-xl: 3rem;
          --spacing-2xl: 4rem;
        }
        .section {
          padding: var(--spacing-xl) 0;
        }
        html {
          scroll-padding-top: 55px;
        }
      }
    </style>

    <link
      href="https://unpkg.com/aos@2.3.4/dist/aos.css"
      rel="stylesheet"
      integrity="sha384-/rJKQnzOkEo+daG0jMjU1IwwY9unxt1NBw3Ef2fmOJ3PW/TfAg2KXVoWwMZQZtw9"
      crossorigin="anonymous"
    />
    <script
      is:inline
      src="https://unpkg.com/aos@2.3.4/dist/aos.js"
      integrity="sha384-n1AULnKdMJlK1oQCLNDL9qZsDgXtH6jRYFCpBtWFc+a9Yve0KSoMn575rk755NJZ"
      crossorigin="anonymous"></script>
  </head>
  <body>
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="grid-background" aria-hidden="true"></div>

    <header class="nav" role="navigation">
      <nav class="container nav__inner">
        <a href="#hero" class="nav__logo" aria-label="PAG3B トップへ">
          <img src="/favicon.svg" alt="PAG3B" width="26" height="26" class="nav__logo-icon" />
          <span class="nav__logo-name">PAG3B</span>
        </a>
        <ul class="nav__list">
          <li><a href="#experience" class="nav__link">展示体験</a></li>
          <li><a href="#design-philosophy" class="nav__link">設計思想</a></li>
          <li><a href="#comparison" class="nav__link">比較</a></li>
          <li><a href="#anatomy" class="nav__link">解剖学</a></li>
          <li><a href="#tech-specs" class="nav__link">技術仕様</a></li>
          <li><a href="#history" class="nav__link">軌跡</a></li>
          <li><a href="#faq" class="nav__link">FAQ</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer__content">
          <p class="footer__text">
            &copy; 2026 PAG3B Project. 天下一キーボードわいわい会 vol.11
          </p>
          <div class="footer__links">
            <a
              href="https://x.com/PAG3B"
              target="_blank"
              rel="noopener noreferrer"
              class="footer__link"
              aria-label="X (旧Twitter) @PAG3B"
            >
              <svg
                class="footer__link-icon"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path>
              </svg>
              <span>@PAG3B</span>
            </a>
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        if (typeof AOS !== "undefined") {
          AOS.init({
            duration: 800,
            easing: "ease-out-cubic",
            once: true,
            offset: 100,
          });
        }
      });
    </script>
  </body>
</html>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: var(--color-nav-bg);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: 0.5em;
    flex-shrink: 0;
    color: var(--color-text-primary);
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    transition: color var(--transition-fast);
  }

  .nav__logo:hover {
    color: var(--color-accent);
  }

  .nav__logo-icon {
    filter: drop-shadow(0 0 6px rgba(59, 130, 246, 0.4));
    transition: filter var(--transition-fast);
  }

  .nav__logo:hover .nav__logo-icon {
    filter: drop-shadow(0 0 10px rgba(59, 130, 246, 0.7));
  }

  .nav__list {
    display: flex;
    list-style: none;
    gap: var(--spacing-md);
    padding: var(--spacing-md) 0;
    overflow-x: auto;
    scrollbar-width: none;
    flex: 1;
  }

  .nav__list::-webkit-scrollbar {
    display: none;
  }

  .nav__link {
    font-family: var(--font-headline);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    transition: color var(--transition-fast);
  }

  .nav__link:hover {
    color: var(--color-accent);
  }

  .footer {
    position: relative;
    padding: var(--spacing-lg) 0;
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border-subtle);
    margin-top: var(--spacing-2xl);
  }

  .footer__content {
    text-align: center;
  }

  .footer__text {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .footer__links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-md);
    margin-top: var(--spacing-md);
  }

  .footer__link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 0.875rem;
    color: var(--color-accent);
  }

  .footer__link:hover {
    color: var(--color-accent-light);
  }

  .footer__link-icon {
    width: 20px;
    height: 20px;
  }

  @media (max-width: 768px) {
    .nav__inner {
      gap: var(--spacing-md);
    }
    .nav__logo-name {
      display: none;
    }
    .nav__list {
      gap: var(--spacing-sm);
      padding: var(--spacing-sm) 0;
    }
    .nav__link {
      font-size: 0.625rem;
    }
  }
</style>
