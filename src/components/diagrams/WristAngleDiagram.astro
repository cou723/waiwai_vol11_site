---
// 手根関節が伸展した状態と軽屈曲状態の比較、およびPAG3Bの後傾角を表す図
---

<figure class="diagram">
  <svg
    viewBox="0 0 700 260"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="手根関節が伸展した状態と軽屈曲状態の比較、およびPAG3Bの後傾角を表す図"
    class="diagram__svg"
  >
    <!-- ===== Left: Wrist extended (bad) ===== -->
    <text x="175" y="26" text-anchor="middle" class="d-label-bad">✗ 手首 伸展（反った状態）</text>
    <text x="175" y="44" text-anchor="middle" class="d-label-sub">一般的な水平キーボード</text>

    <!-- Flat keyboard surface -->
    <rect x="55" y="195" width="240" height="14" rx="3" class="d-kbd-flat"/>
    <!-- Keyboard label -->
    <text x="175" y="220" text-anchor="middle" class="d-tiny">キーボード（水平）</text>

    <!-- Forearm: roughly horizontal, going right -->
    <!-- Forearm bone -->
    <line x1="55" y1="130" x2="175" y2="130" class="d-bone" stroke-dasharray="6,3"/>
    <!-- Forearm outline top -->
    <path d="M 55 115 Q 100 110 175 118" class="d-skin-bad" fill="none"/>
    <!-- Forearm outline bottom -->
    <path d="M 55 145 Q 100 148 175 143" class="d-skin-bad" fill="none"/>

    <!-- Wrist joint point -->
    <circle cx="175" cy="130" r="5" class="d-joint"/>

    <!-- Hand: bent back (extended) relative to forearm -->
    <!-- Hand goes up then flat toward keys -->
    <path d="M 175 130 Q 195 100 215 100 L 255 100" class="d-skin-bad" fill="none" stroke-width="18" stroke-linecap="round"/>
    <path d="M 175 130 Q 195 100 215 100 L 255 100" class="d-bone" fill="none" stroke-width="1" stroke-dasharray="5,3"/>

    <!-- Fingers pressing down to keys -->
    <line x1="225" y1="100" x2="225" y2="195" class="d-finger-bad"/>
    <line x1="240" y1="100" x2="240" y2="195" class="d-finger-bad"/>
    <line x1="255" y1="100" x2="255" y2="195" class="d-finger-bad"/>

    <!-- Angle arc showing extension -->
    <path d="M 195 130 A 22 22 0 0 0 175 108" class="d-angle-arc-bad" fill="none"/>
    <text x="195" y="115" class="d-angle-text-bad">伸展</text>
    <text x="193" y="127" class="d-angle-text-bad">↑危険</text>

    <!-- Divider -->
    <line x1="350" y1="15" x2="350" y2="250" class="d-divider"/>

    <!-- ===== Right: Wrist natural + backward tilt ===== -->
    <text x="525" y="26" text-anchor="middle" class="d-label-good">✓ 手首 軽屈曲（PAG3B）</text>
    <text x="525" y="44" text-anchor="middle" class="d-label-sub">後傾角（Backward-tilting）採用</text>

    <!-- Tilted keyboard surface (angled) -->
    <!-- Keyboard tilted ~15deg, higher at back -->
    <path d="M 385 215 L 625 195" class="d-kbd-good" stroke-width="14" stroke-linecap="round"/>
    <text x="510" y="230" text-anchor="middle" class="d-tiny d-tiny-accent">キーボード（後傾）</text>

    <!-- Forearm roughly horizontal -->
    <line x1="385" y1="130" x2="490" y2="130" class="d-bone" stroke-dasharray="6,3"/>
    <path d="M 385 115 Q 430 110 490 118" class="d-skin-good" fill="none"/>
    <path d="M 385 145 Q 430 148 490 143" class="d-skin-good" fill="none"/>

    <!-- Wrist joint point -->
    <circle cx="490" cy="130" r="5" class="d-joint d-joint--good"/>

    <!-- Hand: slight flexion (0-10 deg downward) - nearly straight continuation -->
    <path d="M 490 130 Q 505 133 525 135 L 600 140" class="d-skin-good" fill="none" stroke-width="18" stroke-linecap="round"/>
    <path d="M 490 130 Q 505 133 525 135 L 600 140" class="d-bone" fill="none" stroke-width="1" stroke-dasharray="5,3"/>

    <!-- Fingers pressing perpendicular to tilted keys -->
    <line x1="540" y1="135" x2="530" y2="205" class="d-finger-good"/>
    <line x1="560" y1="136" x2="550" y2="202" class="d-finger-good"/>
    <line x1="580" y1="138" x2="570" y2="199" class="d-finger-good"/>

    <!-- Tilt angle annotation -->
    <!-- Reference horizontal -->
    <line x1="385" y1="215" x2="440" y2="215" class="d-ref-line"/>
    <path d="M 420 215 A 30 30 0 0 0 407 202" class="d-angle-arc-good" fill="none"/>
    <text x="430" y="208" class="d-angle-text-good">後傾角</text>

    <!-- Wrist angle label -->
    <text x="493" y="122" class="d-angle-text-good">0〜10°</text>
    <text x="493" y="113" class="d-angle-text-good">掌屈</text>
  </svg>

  <figcaption class="diagram__caption">
    左：手首を反らせた伸展状態は腱鞘炎の原因となる。右：PAG3B の後傾角により、手首をほぼ真っ直ぐ（軽屈曲）のままキーを押せる。
  </figcaption>
</figure>

<style>
  .diagram {
    margin: var(--spacing-lg) 0;
  }

  .diagram__svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .diagram__caption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-align: center;
    margin-top: var(--spacing-sm);
    line-height: 1.6;
    opacity: 0.8;
  }

  .d-label-bad {
    font-family: var(--font-headline, sans-serif);
    font-size: 13px;
    fill: #ef4444;
    font-weight: 600;
  }

  .d-label-good {
    font-family: var(--font-headline, sans-serif);
    font-size: 13px;
    fill: #22c55e;
    font-weight: 600;
  }

  .d-label-sub {
    font-family: monospace;
    font-size: 10px;
    fill: var(--color-text-secondary);
  }

  .d-kbd-flat {
    fill: var(--color-bg-tertiary);
    stroke: rgba(229,229,229,0.25);
    stroke-width: 1;
  }

  .d-kbd-good {
    stroke: rgba(59,130,246,0.5);
    stroke-linecap: round;
  }

  .d-bone {
    stroke: rgba(229,229,229,0.2);
    stroke-width: 1;
    fill: none;
  }

  .d-skin-bad {
    stroke: #ef4444;
    stroke-width: 18;
    stroke-linecap: round;
    opacity: 0.25;
  }

  .d-skin-good {
    stroke: #3b82f6;
    stroke-width: 18;
    stroke-linecap: round;
    opacity: 0.25;
  }

  .d-joint {
    fill: var(--color-text-secondary);
    stroke: rgba(229,229,229,0.4);
    stroke-width: 1.5;
  }

  .d-joint--good {
    fill: #3b82f6;
  }

  .d-finger-bad {
    stroke: #ef4444;
    stroke-width: 2;
    opacity: 0.7;
    stroke-linecap: round;
  }

  .d-finger-good {
    stroke: #3b82f6;
    stroke-width: 2;
    opacity: 0.8;
    stroke-linecap: round;
  }

  .d-angle-arc-bad {
    stroke: #ef4444;
    stroke-width: 1.5;
    opacity: 0.8;
  }

  .d-angle-arc-good {
    stroke: #22c55e;
    stroke-width: 1.5;
    opacity: 0.8;
  }

  .d-angle-text-bad {
    font-family: monospace;
    font-size: 9px;
    fill: #ef4444;
  }

  .d-angle-text-good {
    font-family: monospace;
    font-size: 9px;
    fill: #22c55e;
  }

  .d-ref-line {
    stroke: rgba(229,229,229,0.15);
    stroke-width: 1;
    stroke-dasharray: 3,3;
  }

  .d-divider {
    stroke: rgba(229,229,229,0.1);
    stroke-width: 1;
  }

  .d-tiny {
    font-family: monospace;
    font-size: 9px;
    fill: var(--color-text-secondary);
    opacity: 0.7;
  }

  .d-tiny-accent {
    fill: rgba(59,130,246,0.7);
  }

  @media (prefers-color-scheme: light) {
    .d-kbd-flat { stroke: rgba(0,0,0,0.25); }
    .d-bone { stroke: rgba(0,0,0,0.2); }
    .d-joint { stroke: rgba(0,0,0,0.4); }
    .d-divider { stroke: rgba(0,0,0,0.1); }
    .d-ref-line { stroke: rgba(0,0,0,0.15); }
  }
</style>
