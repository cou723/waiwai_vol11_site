---
import TechButton from '@/components/ui/TechButton.astro';
import { projectMeta } from '@/data/content';
import type { AcronymEntry } from '@/data/content';
---

<section id="hero" class="hero">
  <!-- Radial spotlight glow -->
  <div class="hero__glow" aria-hidden="true"></div>

  <!-- Scan line animation -->
  <div class="hero__scan" aria-hidden="true"></div>

  <!-- Huge background watermark text -->
  <div class="hero__watermark" aria-hidden="true">PAG3B</div>

  <!-- Giant background icon -->
  <div class="hero__bg-icon" aria-hidden="true">
    <img src="/favicon.svg" alt="" />
  </div>

  <!-- HUD corner brackets -->
  <div class="hero__hud" aria-hidden="true">
    <span class="hud-corner hud-corner--tl"></span>
    <span class="hud-corner hud-corner--tr"></span>
    <span class="hud-corner hud-corner--bl"></span>
    <span class="hud-corner hud-corner--br"></span>
  </div>

  <div class="container hero__container">
    <div class="hero__layout">
      <div class="hero__content">
        <p class="hero__event">
          <span class="hero__event-dot" aria-hidden="true"></span>
          天下一キーボードわいわい会 vol.11
        </p>
        <div class="hero__acronym" aria-label={projectMeta.fullName}>
          {projectMeta.acronym.map((entry: AcronymEntry) => (
            <div class="hero__acronym-row">
              <span class="hero__acronym-letter">{entry.letter}</span>
              <span class="hero__acronym-english">{entry.english}</span>
              <span class="hero__acronym-sep" aria-hidden="true">／</span>
              <span class="hero__acronym-japanese">{entry.japanese}</span>
            </div>
          ))}
        </div>
        <h1 class="hero__title">{projectMeta.name}</h1>
        <p class="hero__tagline">{projectMeta.tagline}</p>
        <div class="hero__cta">
          <TechButton href="#experience" variant="primary" size="lg">
            この展示を体験する
          </TechButton>
          <TechButton href="#tech-specs" variant="secondary" size="lg">
            技術仕様を見る
          </TechButton>
        </div>
      </div>

      <div class="hero__visual" aria-hidden="true">
        <img src="/favicon.svg" alt="" class="hero__icon" />
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <span class="scroll-indicator"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--spacing-2xl);
    padding-bottom: var(--spacing-2xl);
    overflow: hidden;
  }

  /* ===== Radial glow ===== */
  .hero__glow {
    position: absolute;
    top: 35%;
    left: 30%;
    width: 600px;
    height: 600px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(59,130,246,0.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* ===== Scan line ===== */
  .hero__scan {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(59,130,246,0.6), transparent);
    animation: scanDown 6s linear infinite;
    pointer-events: none;
    z-index: 1;
  }

  @keyframes scanDown {
    0%   { top: 0%; opacity: 0; }
    5%   { opacity: 1; }
    95%  { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }

  /* ===== Watermark ===== */
  .hero__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-headline);
    font-size: clamp(12rem, 30vw, 22rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(59,130,246,0.07);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    line-height: 1;
  }

  /* ===== Giant background icon ===== */
  .hero__bg-icon {
    position: absolute;
    top: 50%;
    left: 35%;
    transform: translate(-50%, -50%);
    width: clamp(500px, 75vw, 900px);
    pointer-events: none;
    user-select: none;
    z-index: 0;
    opacity: 0.045;
    animation: bgIconDrift 20s ease-in-out infinite;
  }

  .hero__bg-icon img {
    width: 100%;
    height: auto;
    filter: blur(1px);
  }

  @keyframes bgIconDrift {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50%       { transform: translate(-50%, -52%) scale(1.03); }
  }

  @media (max-width: 768px) {
    .hero__bg-icon {
      left: 50%;
    }
  }

  /* ===== HUD brackets ===== */
  .hero__hud {
    position: absolute;
    inset: 16px;
    pointer-events: none;
    z-index: 1;
  }

  .hud-corner {
    position: absolute;
    width: 24px;
    height: 24px;
  }

  .hud-corner::before,
  .hud-corner::after {
    content: '';
    position: absolute;
    background: rgba(59,130,246,0.4);
  }

  .hud-corner::before { width: 100%; height: 2px; }
  .hud-corner::after  { width: 2px; height: 100%; }

  .hud-corner--tl { top: 0; left: 0; }
  .hud-corner--tl::before { top: 0; left: 0; }
  .hud-corner--tl::after  { top: 0; left: 0; }

  .hud-corner--tr { top: 0; right: 0; }
  .hud-corner--tr::before { top: 0; right: 0; }
  .hud-corner--tr::after  { top: 0; right: 0; }

  .hud-corner--bl { bottom: 0; left: 0; }
  .hud-corner--bl::before { bottom: 0; left: 0; }
  .hud-corner--bl::after  { bottom: 0; left: 0; }

  .hud-corner--br { bottom: 0; right: 0; }
  .hud-corner--br::before { bottom: 0; right: 0; }
  .hud-corner--br::after  { bottom: 0; right: 0; }

  /* ===== Layout ===== */
  .hero__container {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .hero__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: var(--spacing-2xl);
  }

  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__icon {
    width: clamp(180px, 28vw, 380px);
    height: auto;
    filter:
      drop-shadow(0 0 40px rgba(59, 130, 246, 0.5))
      drop-shadow(0 0 80px rgba(59, 130, 246, 0.2));
    animation: iconFloat 6s ease-in-out infinite;
  }

  @keyframes iconFloat {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50%       { transform: translateY(-12px) rotate(1deg); }
  }

  /* ===== Main content ===== */
  .hero__content {
    max-width: 680px;
  }

  .hero__event {
    display: flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: var(--spacing-sm);
  }

  .hero__event-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: dotPulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes dotPulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(59,130,246,0.6); }
    50%       { opacity: 0.7; box-shadow: 0 0 0 5px rgba(59,130,246,0); }
  }

  .hero__acronym {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: var(--spacing-md);
    border-left: 2px solid rgba(59,130,246,0.3);
    padding-left: 0.75em;
  }

  .hero__acronym-row {
    display: flex;
    align-items: baseline;
    gap: 0.5em;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.6;
  }

  .hero__acronym-letter {
    color: var(--color-accent);
    font-weight: 700;
    min-width: 2em;
    flex-shrink: 0;
  }

  .hero__acronym-english {
    color: var(--color-text-primary);
  }

  .hero__acronym-sep {
    color: var(--color-text-secondary);
    opacity: 0.5;
  }

  .hero__acronym-japanese {
    color: var(--color-text-secondary);
  }

  .hero__title {
    font-family: var(--font-headline);
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 900;
    line-height: 0.9;
    margin-bottom: var(--spacing-lg);
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    text-shadow:
      0 0 40px rgba(59,130,246,0.5),
      0 0 80px rgba(59,130,246,0.2);
  }

  .hero__tagline {
    font-family: var(--font-headline);
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 600;
    line-height: 1.6;
    margin-bottom: var(--spacing-lg);
    color: var(--color-text-secondary);
    max-width: 480px;
    border-left: 3px solid var(--color-accent);
    padding-left: 0.875em;
    letter-spacing: 0.01em;
  }

  .hero__cta {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  /* ===== Scroll indicator ===== */
  .hero__scroll {
    position: absolute;
    bottom: var(--spacing-lg);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .scroll-indicator {
    width: 2px;
    height: 40px;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    animation: scrollBounce 2s infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: scaleY(0.5); opacity: 0.5; }
    50%       { transform: scaleY(1); opacity: 1; }
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .hero {
      padding-top: var(--spacing-xl);
      padding-bottom: var(--spacing-xl);
    }

    .hero__layout {
      grid-template-columns: 1fr;
    }

    .hero__visual {
      display: none;
    }

    .hero__scroll {
      display: none;
    }

    .hero__title {
      font-size: clamp(3rem, 18vw, 5rem);
    }

    .hero__cta {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
